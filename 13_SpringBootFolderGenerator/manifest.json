                    "sizes": "192x192"
                }
            ]
        }
    ],
    "share_target": {
        "action": "/",
        "method": "GET",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url"
        }
    },
    "file_handlers": [
        {
            "action": "/",
            "accept": {
                "text/plain": [".txt"]
            }
        }
    ],
    "launch_handler": {
        "client_mode": "focus-existing"
    },
    "protocol_handlers": [
        {
            "protocol": "web+project",
            "url": "/?type=%s"
        }
    ],
    "note_taking": {
        "new_note_url": "/"
    },
    "widgets": [],
    "edge_side_panel": {
        "preferred_width": 440
    },
    "scope_extensions": [
        {
            "origin": "project_url"
        },
        {
            "origin": "project_url/*"
        }
    ],
    "iarc_rating_id": "12345678",
    "related_applications": [
        {
            "id": "com.attickok.project",
            "url": "project_url",
            "platform": "play"
        }
    ],
    "prefer_related_applications": false
