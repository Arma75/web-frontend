            "protocol": "web+matmal",
            "url": "/?type=%s"
        }
    ],
    "note_taking": {
        "new_note_url": "/"
    },
    "widgets": [],
    "edge_side_panel": {
        "preferred_width": 440
    },
    "scope_extensions": [
        {
            "origin": "https://matmal-no-ad.netlify.app/"
        },
        {
            "origin": "https://matmal-no-ad.netlify.app//*"
        }
    ],
    "iarc_rating_id": "12345678",
    "related_applications": [
        {
            "platform": "play",
            "url": "https://play.google.com/store/apps/details?id=com.attickok.matmal-no-ad",
            "id": "com.attickok.matmal-no-ad"
        }
    ],
    "prefer_related_applications": false
